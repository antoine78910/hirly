{
  "name": "hirly",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "bun run --workspaces --if-present format",
    "lint": "bun run --workspaces --if-present lint",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "test": "if [ -f tests/workspace-isolation.test.ts ]; then bun test ./tests/workspace-isolation.test.ts; fi && bun run --workspaces --if-present test",
    "build": "bun run --workspaces --if-present build"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
