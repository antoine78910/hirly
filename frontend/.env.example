REACT_APP_BACKEND_URL=http://localhost:8000
# Supabase project URL (https://<project-ref>.supabase.co) — do NOT append /rest/v1
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
REACT_APP_GOOGLE_MAPS_API_KEY=

# PostHog runs additively beside DataFast. Leave unset to disable it.
REACT_APP_POSTHOG_TOKEN=
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
# Build-time switch: changing profiles requires a rebuild/redeploy.
# Keep false unless replay inspection and governance gates pass. Vendor-side recording
# stop is a faster supplementary control; rollback still rebuilds/deploys Profile A.
REACT_APP_POSTHOG_REPLAY_ENABLED=false
REACT_APP_ADMIN_POSTHOG_ANALYTICS_ENABLED=false
REACT_APP_POSTHOG_ADMIN_DASHBOARD_URL=

# Use these when testing the real backend locally.
REACT_APP_DEMO_MODE=false
REACT_APP_DEV_BYPASS_AUTH=false
REACT_APP_DEV_LOGIN_ENABLED=false

# Internal Greenhouse final-submit testing. Keep disabled unless testing with an allowlisted account.
BROWSER_SUBMIT_DRY_RUN=true
GREENHOUSE_REAL_SUBMIT_ENABLED=false
REAL_SUBMIT_ALLOWED_EMAILS=
REACT_APP_ENABLE_INTERNAL_SUBMIT_TEST=false
REACT_APP_REAL_SUBMIT_ALLOWED_EMAILS=

# Backend-only Stripe subscription configuration.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_BASIC_WEEKLY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_WEEKLY=
STRIPE_PRICE_ULTRA=
STRIPE_PRICE_ULTRA_WEEKLY=
STRIPE_PRICE_ONBOARDING_MONTHLY=
STRIPE_PRICE_ONBOARDING_QUARTERLY=
MASTER_BILLING_CODE=424242
FRONTEND_URL=http://localhost:3000
