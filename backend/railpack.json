{
  "$schema": "https://schema.railpack.com/schema.json",
  "buildAptPackages": [
    "libnss3",
    "libnspr4",
    "libatk1.0-0",
    "libatk-bridge2.0-0",
    "libcups2",
    "libdrm2",
    "libxkbcommon0",
    "libxcomposite1",
    "libxdamage1",
    "libxfixes3",
    "libxrandr2",
    "libgbm1",
    "libasound2",
    "libpango-1.0-0",
    "libcairo2",
    "fonts-liberation"
  ],
  "steps": {
    "build": {
      "commands": [
        "...",
        "playwright install chromium",
        "python -m patchright install chromium"
      ],
      "variables": {
        "PLAYWRIGHT_BROWSERS_PATH": "/app/.playwright-browsers"
      }
    }
  },
  "deploy": {
    "aptPackages": [
      "libnss3",
      "libnspr4",
      "libatk1.0-0",
      "libatk-bridge2.0-0",
      "libcups2",
      "libdrm2",
      "libxkbcommon0",
      "libxcomposite1",
      "libxdamage1",
      "libxfixes3",
      "libxrandr2",
      "libgbm1",
      "libasound2",
      "libpango-1.0-0",
      "libcairo2",
      "fonts-liberation"
    ],
    "startCommand": "python run_server.py",
    "variables": {
      "PLAYWRIGHT_BROWSERS_PATH": "/app/.playwright-browsers"
    }
  }
}
